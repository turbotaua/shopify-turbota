{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .custom-discount-form .contact__button {
    margin-top: 30px;
  }
{%- endstyle -%}

<div class="row page-width page-width--narrow section-{{ section.id }}-padding">
  <div class="collapsible-content__inner">
      {%- render 'custom-discount-form', 
     settings_id: section.settings.settings_id,
     title: section.settings.title,
     description: section.settings.description,
     field_label: section.settings.field_label,
     error: section.settings.error,
     btn_text: section.settings.btn_text
  -%}
  </div>

</div>
{% schema %}
  {
    "name": "Discount Code Form",
    "settings": [
      {
        "type": "text",
        "id": "settings_id",
        "label": "Discount Settings ID",
        "info": "Use a corresponding ID value which you've entered to the ID field in one of your Discount Settings section"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "richtext",
        "id": "description",
        "label": "Description"
      },
      {
        "type": "text",
        "id": "field_label",
        "label": "Discount field label"
      },
      {
        "type": "text",
        "id": "error",
        "label": "Error Message"
      },
      {
        "type": "text",
        "id": "btn_text",
        "label": "Button text"
      },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "presets": [
      {
        "name": "Custom Discount Form"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}